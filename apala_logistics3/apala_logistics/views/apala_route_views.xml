<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Route Form View -->
    <record id="route_form_view" model="ir.ui.view">
        <field name="name">apala.route.form</field>
        <field name="model">apala.route</field>
        <field name="arch" type="xml">
            <form string="Route">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Route Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="origin_city"/>
                            <field name="destination_city"/>
                            <field name="corridor"/>
                        </group>
                        <group>
                            <field name="distance_km"/>
                            <field name="transit_days"/>
                            <field name="toll_cost"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="waypoint_sequence"
                               placeholder="e.g. Morogoro, Dodoma, Tabora"/>
                        <field name="description" placeholder="Route description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Route List View -->
    <record id="route_list_view" model="ir.ui.view">
        <field name="name">apala.route.tree</field>
        <field name="model">apala.route</field>
        <field name="arch" type="xml">
            <tree string="Routes">
                <field name="code"/>
                <field name="name"/>
                <field name="origin_city"/>
                <field name="destination_city"/>
                <field name="distance_km"/>
                <field name="transit_days"/>
                <field name="corridor"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Route Search View -->
    <record id="route_search_view" model="ir.ui.view">
        <field name="name">apala.route.search</field>
        <field name="model">apala.route</field>
        <field name="arch" type="xml">
            <search string="Search Routes">
                <field name="name"/>
                <field name="code"/>
                <field name="origin_city"/>
                <field name="destination_city"/>
                <filter string="Central Corridor" name="central" domain="[('corridor','=','central')]"/>
                <filter string="Northern Corridor" name="northern" domain="[('corridor','=','northern')]"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Corridor" name="group_corridor" context="{'group_by': 'corridor'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Route Action -->
    <record id="action_apala_route" model="ir.actions.act_window">
        <field name="name">Routes</field>
        <field name="res_model">apala.route</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="route_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first route
            </p>
        </field>
    </record>

</odoo>
