<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Storage Contract Form View -->
    <record id="storage_contract_form_view" model="ir.ui.view">
        <field name="name">apala.storage.contract.form</field>
        <field name="model">apala.storage.contract</field>
        <field name="arch" type="xml">
            <form string="Storage Contract">
                <header>
                    <button name="action_activate" string="Activate" type="object"
                            states="draft" class="oe_highlight"/>
                    <button name="action_create_storage_invoice" string="Create Invoice" type="object"
                            states="active" class="oe_highlight"/>
                    <button name="action_terminate" string="Terminate" type="object"
                            states="active" confirm="Are you sure you want to terminate this contract?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,expired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object"
                                class="oe_stat_button" icon="fa-pencil-square-o">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_id"/>
                            <field name="storage_type"/>
                            <field name="warehouse_id"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="billing_cycle"/>
                            <field name="auto_renew"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="allocated_m2"/>
                            <field name="allocated_m3"/>
                        </group>
                        <group>
                            <field name="daily_rate" widget="monetary"/>
                            <field name="handling_rate" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Contract notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Storage Contract List View -->
    <record id="storage_contract_list_view" model="ir.ui.view">
        <field name="name">apala.storage.contract.tree</field>
        <field name="model">apala.storage.contract</field>
        <field name="arch" type="xml">
            <tree string="Storage Contracts" decoration-info="state=='draft'"
                  decoration-success="state=='active'" decoration-muted="state in ('expired','terminated')">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="storage_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="allocated_m3"/>
                <field name="daily_rate" widget="monetary"/>
                <field name="billing_cycle"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Storage Contract Search View -->
    <record id="storage_contract_search_view" model="ir.ui.view">
        <field name="name">apala.storage.contract.search</field>
        <field name="model">apala.storage.contract</field>
        <field name="arch" type="xml">
            <search string="Search Storage Contracts">
                <field name="name"/>
                <field name="customer_id"/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Expired" name="expired" domain="[('state','=','expired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="group_customer" context="{'group_by': 'customer_id'}"/>
                    <filter string="Storage Type" name="group_type" context="{'group_by': 'storage_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Storage Contract Action -->
    <record id="action_apala_storage_contract" model="ir.actions.act_window">
        <field name="name">Storage Contracts</field>
        <field name="res_model">apala.storage.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="storage_contract_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first storage contract
            </p>
        </field>
    </record>

</odoo>
