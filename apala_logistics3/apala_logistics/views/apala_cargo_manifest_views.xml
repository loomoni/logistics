<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Cargo Manifest Form View -->
    <record id="cargo_manifest_form_view" model="ir.ui.view">
        <field name="name">apala.cargo.manifest.form</field>
        <field name="model">apala.cargo.manifest</field>
        <field name="arch" type="xml">
            <form string="Cargo Manifest">
                <header>
                    <button name="action_issue" string="Issue" type="object"
                            states="draft" class="oe_highlight"/>
                    <button name="action_deliver" string="Mark Delivered" type="object"
                            states="issued" class="oe_highlight"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,issued,delivered"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="transport_order_id"/>
                            <field name="shipper_id"/>
                            <field name="consignee_id"/>
                        </group>
                        <group>
                            <field name="manifest_date"/>
                            <field name="total_weight_kg"/>
                            <field name="total_pieces"/>
                            <field name="stock_picking_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cargo Lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit"/>
                                    <field name="weight_kg"/>
                                    <field name="volume_m3"/>
                                    <field name="declared_value"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Special Instructions">
                            <field name="special_instructions"
                                   placeholder="Special handling instructions..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Cargo Manifest List View -->
    <record id="cargo_manifest_list_view" model="ir.ui.view">
        <field name="name">apala.cargo.manifest.tree</field>
        <field name="model">apala.cargo.manifest</field>
        <field name="arch" type="xml">
            <tree string="Cargo Manifests" decoration-info="state=='draft'"
                  decoration-success="state=='delivered'">
                <field name="name"/>
                <field name="transport_order_id"/>
                <field name="shipper_id"/>
                <field name="consignee_id"/>
                <field name="manifest_date"/>
                <field name="total_weight_kg"/>
                <field name="total_pieces"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Cargo Manifest Search View -->
    <record id="cargo_manifest_search_view" model="ir.ui.view">
        <field name="name">apala.cargo.manifest.search</field>
        <field name="model">apala.cargo.manifest</field>
        <field name="arch" type="xml">
            <search string="Search Cargo Manifests">
                <field name="name"/>
                <field name="transport_order_id"/>
                <field name="shipper_id"/>
                <field name="consignee_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Issued" name="issued" domain="[('state','=','issued')]"/>
                <filter string="Delivered" name="delivered" domain="[('state','=','delivered')]"/>
                <group expand="0" string="Group By">
                    <filter string="Transport Order" name="group_to" context="{'group_by': 'transport_order_id'}"/>
                    <filter string="Shipper" name="group_shipper" context="{'group_by': 'shipper_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Cargo Manifest Action -->
    <record id="action_apala_cargo_manifest" model="ir.actions.act_window">
        <field name="name">Cargo Manifests</field>
        <field name="res_model">apala.cargo.manifest</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="cargo_manifest_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first cargo manifest
            </p>
        </field>
    </record>

</odoo>
