<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_trip_expense">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">TRIP EXPENSE SUMMARY</h2>
                        <h3 class="text-center"><t t-esc="doc.name"/></h3>

                        <div class="row mt-4">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Vehicle:</strong></td>
                                        <td><t t-esc="doc.vehicle_id.name or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Driver:</strong></td>
                                        <td><t t-esc="doc.driver_id.name or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Route:</strong></td>
                                        <td><t t-esc="doc.route_id.name or '-'"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Departure:</strong></td>
                                        <td><t t-esc="doc.departure_date or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Arrival:</strong></td>
                                        <td><t t-esc="doc.arrival_date or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Distance:</strong></td>
                                        <td><t t-esc="'%.1f km' % doc.distance_km"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-6">
                                <strong>Odometer Start:</strong>
                                <t t-esc="'%.1f km' % doc.odometer_start"/>
                            </div>
                            <div class="col-6">
                                <strong>Odometer End:</strong>
                                <t t-esc="'%.1f km' % doc.odometer_end"/>
                            </div>
                        </div>

                        <h4 class="mt-4">Expense Details</h4>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Employee</th>
                                    <th>Receipt Ref</th>
                                    <th class="text-right">Amount (TZS)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.expense_ids" t-as="exp">
                                    <tr>
                                        <td><t t-esc="exp.date"/></td>
                                        <td><t t-esc="exp.expense_type"/></td>
                                        <td><t t-esc="exp.description or '-'"/></td>
                                        <td><t t-esc="exp.employee_id.name or '-'"/></td>
                                        <td><t t-esc="exp.receipt_ref or '-'"/></td>
                                        <td class="text-right"><t t-esc="'{:,.2f}'.format(exp.amount)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="5"><strong>TOTAL</strong></td>
                                    <td class="text-right"><strong><t t-esc="'{:,.2f}'.format(doc.total_expenses)"/></strong></td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <p>____________________________</p>
                                <p><strong>Driver</strong></p>
                            </div>
                            <div class="col-4 text-center">
                                <p>____________________________</p>
                                <p><strong>Operations Manager</strong></p>
                            </div>
                            <div class="col-4 text-center">
                                <p>____________________________</p>
                                <p><strong>Finance</strong></p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
