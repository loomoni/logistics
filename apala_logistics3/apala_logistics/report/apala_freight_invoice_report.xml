<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_freight_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">FREIGHT INVOICE</h2>
                        <h3 class="text-center"><t t-esc="doc.name"/></h3>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Customer:</strong><br/>
                                <t t-if="doc.customer_id">
                                    <t t-esc="doc.customer_id.name"/><br/>
                                    <t t-esc="doc.customer_id.street or ''"/><br/>
                                    <t t-esc="doc.customer_id.city or ''"/>
                                    <t t-if="doc.customer_id.vat">
                                        <br/>TIN: <t t-esc="doc.customer_id.vat"/>
                                    </t>
                                </t>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td><strong>Freight Type:</strong></td>
                                        <td><t t-esc="doc.freight_type"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Mode:</strong></td>
                                        <td><t t-esc="doc.mode"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>B/L Number:</strong></td>
                                        <td><t t-esc="doc.bl_number or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Incoterm:</strong></td>
                                        <td><t t-esc="doc.incoterm_id.name or '-'"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-6">
                                <strong>Origin:</strong>
                                <t t-esc="doc.origin_port or ''"/>
                                (<t t-esc="doc.origin_country.name or '-'"/>)
                            </div>
                            <div class="col-6">
                                <strong>Destination:</strong>
                                <t t-esc="doc.destination_port or ''"/>
                                (<t t-esc="doc.destination_country.name or '-'"/>)
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-4">
                                <strong>Commodity:</strong>
                                <t t-esc="doc.commodity or '-'"/>
                            </div>
                            <div class="col-4">
                                <strong>HS Code:</strong>
                                <t t-esc="doc.hs_code or '-'"/>
                            </div>
                            <div class="col-4">
                                <strong>Gross Weight:</strong>
                                <t t-esc="'%.2f kg' % doc.gross_weight_kg"/>
                            </div>
                        </div>

                        <h4 class="mt-4">Charges Breakdown</h4>
                        <table class="table table-sm table-bordered">
                            <tbody>
                                <tr>
                                    <td>Freight Cost</td>
                                    <td class="text-right"><t t-esc="'{:,.2f}'.format(doc.freight_cost)"/> TZS</td>
                                </tr>
                                <tr>
                                    <td>Customs Duty</td>
                                    <td class="text-right"><t t-esc="'{:,.2f}'.format(doc.customs_duty)"/> TZS</td>
                                </tr>
                                <tr>
                                    <td>Other Charges</td>
                                    <td class="text-right"><t t-esc="'{:,.2f}'.format(doc.other_charges)"/> TZS</td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td><strong>TOTAL</strong></td>
                                    <td class="text-right"><strong><t t-esc="'{:,.2f}'.format(doc.total_cost)"/> TZS</strong></td>
                                </tr>
                            </tfoot>
                        </table>

                        <t t-if="doc.notes">
                            <h5>Notes</h5>
                            <p><t t-esc="doc.notes"/></p>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
