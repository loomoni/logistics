<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report Actions -->
    <record id="action_report_waybill" model="ir.actions.report">
        <field name="name">Waybill / Consignment Note</field>
        <field name="model">apala.cargo.manifest</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">apala_logistics.report_waybill</field>
        <field name="report_file">apala_logistics.report_waybill</field>
        <field name="binding_model_id" ref="model_apala_cargo_manifest"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <record id="action_report_trip_expense" model="ir.actions.report">
        <field name="name">Trip Expense Summary</field>
        <field name="model">apala.trip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">apala_logistics.report_trip_expense</field>
        <field name="report_file">apala_logistics.report_trip_expense</field>
        <field name="binding_model_id" ref="model_apala_trip"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <record id="action_report_freight_invoice" model="ir.actions.report">
        <field name="name">Freight Invoice</field>
        <field name="model">apala.freight.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">apala_logistics.report_freight_invoice</field>
        <field name="report_file">apala_logistics.report_freight_invoice</field>
        <field name="binding_model_id" ref="model_apala_freight_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
