<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Demo Customers -->
        <record id="demo_partner_abacus" model="res.partner">
            <field name="name">Abacus Ltd</field>
            <field name="city">Dar es Salaam</field>
            <field name="country_id" ref="base.tz"/>
            <field name="email">info@abacus.co.tz</field>
            <field name="phone">+255 222 123 456</field>
            <field name="is_company" eval="True"/>
        </record>

        <record id="demo_partner_bugando" model="res.partner">
            <field name="name">Bugando Medical Centre</field>
            <field name="city">Mwanza</field>
            <field name="country_id" ref="base.tz"/>
            <field name="email">logistics@bugando.ac.tz</field>
            <field name="phone">+255 282 500 799</field>
            <field name="is_company" eval="True"/>
        </record>

        <record id="demo_partner_silent_ocean" model="res.partner">
            <field name="name">Silent Ocean Ltd</field>
            <field name="city">Dar es Salaam</field>
            <field name="country_id" ref="base.tz"/>
            <field name="email">info@silentocean.co.tz</field>
            <field name="phone">+255 222 789 012</field>
            <field name="is_company" eval="True"/>
        </record>

        <!-- Demo Vehicles -->
        <record id="demo_vehicle_brand_scania" model="fleet.vehicle.model.brand">
            <field name="name">SCANIA</field>
        </record>

        <record id="demo_vehicle_model_r500" model="fleet.vehicle.model">
            <field name="name">R500</field>
            <field name="brand_id" ref="demo_vehicle_brand_scania"/>
        </record>

        <record id="demo_vehicle_model_g460" model="fleet.vehicle.model">
            <field name="name">G460</field>
            <field name="brand_id" ref="demo_vehicle_brand_scania"/>
        </record>

        <record id="demo_vehicle_brand_isuzu" model="fleet.vehicle.model.brand">
            <field name="name">ISUZU</field>
        </record>

        <record id="demo_vehicle_model_fvr" model="fleet.vehicle.model">
            <field name="name">FVR</field>
            <field name="brand_id" ref="demo_vehicle_brand_isuzu"/>
        </record>

        <record id="demo_vehicle_1" model="fleet.vehicle">
            <field name="model_id" ref="demo_vehicle_model_r500"/>
            <field name="license_plate">T123ABC</field>
            <field name="vehicle_class">prime_mover</field>
            <field name="max_payload_kg">30000</field>
            <field name="is_apala_vehicle" eval="True"/>
        </record>

        <record id="demo_vehicle_2" model="fleet.vehicle">
            <field name="model_id" ref="demo_vehicle_model_g460"/>
            <field name="license_plate">T456DEF</field>
            <field name="vehicle_class">prime_mover</field>
            <field name="max_payload_kg">28000</field>
            <field name="is_apala_vehicle" eval="True"/>
        </record>

        <record id="demo_vehicle_3" model="fleet.vehicle">
            <field name="model_id" ref="demo_vehicle_model_fvr"/>
            <field name="license_plate">T789GHI</field>
            <field name="vehicle_class">rigid_truck</field>
            <field name="max_payload_kg">10000</field>
            <field name="is_apala_vehicle" eval="True"/>
        </record>

        <!-- Demo Driver Employees -->
        <record id="demo_driver_john" model="hr.employee">
            <field name="name">John Msigwa</field>
            <field name="is_driver" eval="True"/>
            <field name="licence_class">class_e</field>
            <field name="licence_expiry">2026-12-31</field>
            <field name="driver_licence_no">TZD-2020-45678</field>
            <field name="job_title">Long-Haul Driver</field>
        </record>

        <record id="demo_driver_peter" model="hr.employee">
            <field name="name">Peter Kimaro</field>
            <field name="is_driver" eval="True"/>
            <field name="licence_class">class_e</field>
            <field name="licence_expiry">2026-06-30</field>
            <field name="driver_licence_no">TZD-2019-12345</field>
            <field name="job_title">Long-Haul Driver</field>
        </record>

        <!-- Demo Transport Orders -->
        <record id="demo_transport_order_1" model="apala.transport.order">
            <field name="customer_id" ref="demo_partner_abacus"/>
            <field name="route_id" ref="route_dar_mwanza"/>
            <field name="cargo_type">general</field>
            <field name="weight_kg">15000</field>
            <field name="vehicle_id" ref="demo_vehicle_1"/>
            <field name="driver_id" ref="demo_driver_john"/>
            <field name="freight_charge">5500000</field>
            <field name="state">confirmed</field>
            <field name="pickup_location">Dar es Salaam</field>
            <field name="delivery_location">Mwanza</field>
        </record>

        <record id="demo_transport_order_2" model="apala.transport.order">
            <field name="customer_id" ref="demo_partner_bugando"/>
            <field name="route_id" ref="route_dar_mwanza"/>
            <field name="cargo_type">general</field>
            <field name="weight_kg">8000</field>
            <field name="vehicle_id" ref="demo_vehicle_3"/>
            <field name="driver_id" ref="demo_driver_peter"/>
            <field name="freight_charge">3200000</field>
            <field name="state">draft</field>
            <field name="pickup_location">Dar es Salaam</field>
            <field name="delivery_location">Mwanza</field>
        </record>

        <!-- Demo Trip -->
        <record id="demo_trip_1" model="apala.trip">
            <field name="transport_order_id" ref="demo_transport_order_1"/>
            <field name="vehicle_id" ref="demo_vehicle_1"/>
            <field name="driver_id" ref="demo_driver_john"/>
            <field name="route_id" ref="route_dar_mwanza"/>
            <field name="state">dispatched</field>
            <field name="odometer_start">125000</field>
            <field name="cash_advance_amount">1200000</field>
        </record>

    </data>
</odoo>
