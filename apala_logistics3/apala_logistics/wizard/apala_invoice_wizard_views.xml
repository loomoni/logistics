<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="invoice_wizard_form_view" model="ir.ui.view">
        <field name="name">apala.invoice.wizard.form</field>
        <field name="model">apala.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Invoice">
                <group>
                    <field name="transport_order_ids" widget="many2many_tags"/>
                    <field name="invoice_date"/>
                    <field name="payment_term_id"/>
                </group>
                <group>
                    <field name="notes" placeholder="Invoice notes..."/>
                </group>
                <footer>
                    <button name="action_create_invoice" string="Create Invoice"
                            type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
