<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Form View (KPI Tiles) -->
    <record id="dashboard_form_view" model="ir.ui.view">
        <field name="name">apala.dashboard.form</field>
        <field name="model">apala.dashboard</field>
        <field name="arch" type="xml">
            <form string="Logistics Dashboard" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>Apala Logistics Dashboard</h1>
                    </div>
                    <div class="row mt-3">
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px;">
                                <button name="action_view_active_trips" type="object" class="btn btn-link p-0">
                                    <span class="o_stat_value" style="font-size:2em;">
                                        <field name="active_trips_count"/>
                                    </span>
                                </button>
                                <span class="o_stat_text">Active Trips</span>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px;">
                                <button name="action_view_pending_orders" type="object" class="btn btn-link p-0">
                                    <span class="o_stat_value" style="font-size:2em;">
                                        <field name="pending_orders_count"/>
                                    </span>
                                </button>
                                <span class="o_stat_text">Pending Orders</span>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px; background:#fff3cd;">
                                <button name="action_view_overdue_trips" type="object" class="btn btn-link p-0">
                                    <span class="o_stat_value" style="font-size:2em; color:#856404;">
                                        <field name="overdue_trips_count"/>
                                    </span>
                                </button>
                                <span class="o_stat_text">Overdue Trips</span>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px; background:#d4edda;">
                                <span class="o_stat_value" style="font-size:2em; color:#155724;">
                                    <field name="deliveries_today"/>
                                </span>
                                <span class="o_stat_text">Deliveries Today</span>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px;">
                                <span class="o_stat_value" style="font-size:1.5em;">
                                    <field name="revenue_this_month" widget="monetary"/>
                                </span>
                                <field name="currency_id" invisible="1"/>
                                <span class="o_stat_text">Revenue This Month</span>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px;">
                                <span class="o_stat_value" style="font-size:1.5em;">
                                    <field name="expenses_this_month" widget="monetary"/>
                                </span>
                                <span class="o_stat_text">Expenses This Month</span>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px;">
                                <span class="o_stat_value" style="font-size:2em;">
                                    <field name="vehicles_available"/>
                                </span>
                                <span class="o_stat_text">Available Vehicles</span>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="o_stat_info text-center p-3" style="border:1px solid #ddd; border-radius:8px;">
                                <span class="o_stat_value" style="font-size:2em;">
                                    <field name="orders_this_month"/>
                                </span>
                                <span class="o_stat_text">Orders This Month</span>
                            </div>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_apala_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">apala.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- ========== Graph Views ========== -->

    <!-- Transport Orders Graph -->
    <record id="transport_order_graph_view" model="ir.ui.view">
        <field name="name">apala.transport.order.graph</field>
        <field name="model">apala.transport.order</field>
        <field name="arch" type="xml">
            <graph string="Transport Orders" type="bar">
                <field name="create_date" type="col" interval="month"/>
                <field name="freight_charge" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Trip Graph -->
    <record id="trip_graph_view" model="ir.ui.view">
        <field name="name">apala.trip.graph</field>
        <field name="model">apala.trip</field>
        <field name="arch" type="xml">
            <graph string="Trips by Route" type="bar">
                <field name="route_id" type="row"/>
                <field name="distance_km" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Trip Expense Graph (Pie) -->
    <record id="trip_expense_graph_view" model="ir.ui.view">
        <field name="name">apala.trip.expense.graph</field>
        <field name="model">apala.trip.expense</field>
        <field name="arch" type="xml">
            <graph string="Expense Breakdown" type="pie">
                <field name="expense_type" type="row"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ========== Pivot Views ========== -->

    <!-- Transport Orders Pivot -->
    <record id="transport_order_pivot_view" model="ir.ui.view">
        <field name="name">apala.transport.order.pivot</field>
        <field name="model">apala.transport.order</field>
        <field name="arch" type="xml">
            <pivot string="Transport Orders Analysis">
                <field name="customer_id" type="row"/>
                <field name="state" type="col"/>
                <field name="freight_charge" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Trip Expenses Pivot -->
    <record id="trip_expense_pivot_view" model="ir.ui.view">
        <field name="name">apala.trip.expense.pivot</field>
        <field name="model">apala.trip.expense</field>
        <field name="arch" type="xml">
            <pivot string="Trip Expenses Analysis">
                <field name="expense_type" type="row"/>
                <field name="date" type="col" interval="month"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ========== Calendar View ========== -->

    <record id="trip_calendar_view" model="ir.ui.view">
        <field name="name">apala.trip.calendar</field>
        <field name="model">apala.trip</field>
        <field name="arch" type="xml">
            <calendar string="Trip Calendar" date_start="departure_date"
                      date_stop="estimated_arrival" color="driver_id"
                      mode="month">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="route_id"/>
            </calendar>
        </field>
    </record>

</odoo>
