<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_waybill">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">WAYBILL / CONSIGNMENT NOTE</h2>
                        <h3 class="text-center"><t t-esc="doc.name"/></h3>

                        <div class="row mt-4">
                            <div class="col-6">
                                <strong>Shipper:</strong><br/>
                                <t t-if="doc.shipper_id">
                                    <t t-esc="doc.shipper_id.name"/><br/>
                                    <t t-esc="doc.shipper_id.street or ''"/><br/>
                                    <t t-esc="doc.shipper_id.city or ''"/>
                                    <t t-if="doc.shipper_id.phone">
                                        <br/>Tel: <t t-esc="doc.shipper_id.phone"/>
                                    </t>
                                </t>
                            </div>
                            <div class="col-6">
                                <strong>Consignee:</strong><br/>
                                <t t-if="doc.consignee_id">
                                    <t t-esc="doc.consignee_id.name"/><br/>
                                    <t t-esc="doc.consignee_id.street or ''"/><br/>
                                    <t t-esc="doc.consignee_id.city or ''"/>
                                    <t t-if="doc.consignee_id.phone">
                                        <br/>Tel: <t t-esc="doc.consignee_id.phone"/>
                                    </t>
                                </t>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-6">
                                <strong>Transport Order:</strong>
                                <t t-esc="doc.transport_order_id.name or '-'"/>
                            </div>
                            <div class="col-3">
                                <strong>Date:</strong>
                                <t t-esc="doc.manifest_date"/>
                            </div>
                            <div class="col-3">
                                <strong>Status:</strong>
                                <t t-esc="doc.state"/>
                            </div>
                        </div>

                        <t t-if="doc.transport_order_id">
                            <div class="row mt-2">
                                <div class="col-4">
                                    <strong>Route:</strong>
                                    <t t-esc="doc.transport_order_id.route_id.name or '-'"/>
                                </div>
                                <div class="col-4">
                                    <strong>Vehicle:</strong>
                                    <t t-esc="doc.transport_order_id.vehicle_id.name or '-'"/>
                                </div>
                                <div class="col-4">
                                    <strong>Driver:</strong>
                                    <t t-esc="doc.transport_order_id.driver_id.name or '-'"/>
                                </div>
                            </div>
                        </t>

                        <h4 class="mt-4">Cargo Details</h4>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th class="text-right">Qty</th>
                                    <th>Unit</th>
                                    <th class="text-right">Weight (kg)</th>
                                    <th class="text-right">Volume (m³)</th>
                                    <th class="text-right">Declared Value (TZS)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.description"/></td>
                                        <td class="text-right"><t t-esc="line.quantity"/></td>
                                        <td><t t-esc="line.unit"/></td>
                                        <td class="text-right"><t t-esc="'%.2f' % line.weight_kg"/></td>
                                        <td class="text-right"><t t-esc="'%.2f' % line.volume_m3"/></td>
                                        <td class="text-right"><t t-esc="'{:,.2f}'.format(line.declared_value)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="3"><strong>Totals</strong></td>
                                    <td class="text-right"><strong><t t-esc="'%.2f' % doc.total_weight_kg"/></strong></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>

                        <t t-if="doc.special_instructions">
                            <h5>Special Instructions</h5>
                            <p><t t-esc="doc.special_instructions"/></p>
                        </t>

                        <!-- QR Code -->
                        <div class="row mt-3">
                            <div class="col-9"/>
                            <div class="col-3 text-right">
                                <img t-att-src="'/report/barcode/QR/%s' % (doc.qr_code_data or doc.name)"
                                     style="width:80px;height:80px;"/>
                                <p style="font-size:8px;"><t t-esc="doc.name"/></p>
                            </div>
                        </div>

                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <p>____________________________</p>
                                <p><strong>Driver Signature</strong></p>
                            </div>
                            <div class="col-4 text-center">
                                <p>____________________________</p>
                                <p><strong>Shipper Signature</strong></p>
                            </div>
                            <div class="col-4 text-center">
                                <p>____________________________</p>
                                <p><strong>Consignee Signature</strong></p>
                            </div>
                        </div>

                        <div class="mt-4" style="font-size: 9px;">
                            <strong>Terms and Conditions:</strong>
                            <p>1. Goods are carried at owner's risk unless otherwise agreed in writing.
                            2. The carrier's liability is limited to the declared value of goods.
                            3. Claims must be filed within 7 days of delivery.
                            4. The carrier is not liable for delays caused by force majeure.
                            5. All disputes shall be subject to Tanzanian law and jurisdiction of Dar es Salaam courts.</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
