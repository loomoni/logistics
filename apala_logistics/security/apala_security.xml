<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Module Category -->
        <record id="module_category_apala_logistics" model="ir.module.category">
            <field name="name">Apala Logistics</field>
            <field name="sequence">50</field>
        </record>

        <!-- Security Groups -->
        <record id="group_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_apala_logistics"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Driver — sees own trips only</field>
        </record>

        <record id="group_user" model="res.groups">
            <field name="name">Dispatcher / Operations</field>
            <field name="category_id" ref="module_category_apala_logistics"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Dispatcher / operations staff</field>
        </record>

        <record id="group_manager" model="res.groups">
            <field name="name">Operations Manager</field>
            <field name="category_id" ref="module_category_apala_logistics"/>
            <field name="implied_ids" eval="[(4, ref('group_user'))]"/>
            <field name="comment">Operations manager — full access</field>
        </record>

    </data>

    <data noupdate="1">

        <!-- Record Rules: Drivers can only see their own trips -->
        <record id="rule_trip_driver" model="ir.rule">
            <field name="name">Trip: Driver sees own trips</field>
            <field name="model_id" ref="model_apala_trip"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_driver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_trip_expense_driver" model="ir.rule">
            <field name="name">Trip Expense: Driver sees own trip expenses</field>
            <field name="model_id" ref="model_apala_trip_expense"/>
            <field name="domain_force">[('trip_id.driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_driver'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
