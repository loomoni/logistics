<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="trip_close_wizard_form_view" model="ir.ui.view">
        <field name="name">apala.trip.close.wizard.form</field>
        <field name="model">apala.trip.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Close Trip">
                <group>
                    <field name="trip_id" readonly="1"/>
                    <field name="arrival_date"/>
                    <field name="odometer_end"/>
                    <field name="fuel_consumed_l"/>
                </group>
                <group>
                    <field name="pod_attachment" filename="pod_filename"/>
                    <field name="pod_filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_close_trip" string="Close Trip"
                            type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
