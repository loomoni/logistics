<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- 3.1 Transport Order Confirmation (to customer) -->
        <record id="email_template_order_confirmed" model="mail.template">
            <field name="name">Apala: Transport Order Confirmed</field>
            <field name="model_id" ref="model_apala_transport_order"/>
            <field name="subject">Transport Order ${object.name} Confirmed — Apala Logistics</field>
            <field name="email_from">${(object.company_id.email or 'info@apalagroup.net')|safe}</field>
            <field name="email_to">${object.customer_id.email or ''}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto;">
    <div style="background: #003366; color: #ffffff; padding: 15px 20px;">
        <h2 style="margin: 0;">APALA LOGISTIC COMPANY LIMITED</h2>
        <p style="margin: 5px 0 0 0; font-size: 12px;">Central Corridor Transport &amp; Logistics</p>
    </div>
    <div style="padding: 20px; border: 1px solid #ddd;">
        <p>Dear ${object.customer_id.name},</p>
        <p>We are pleased to confirm your transport order <strong>${object.name}</strong>.</p>
        <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
            <tr><td style="padding: 5px; font-weight: bold;">Route:</td>
                <td style="padding: 5px;">${object.route_id.name or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Cargo Type:</td>
                <td style="padding: 5px;">${object.cargo_type or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Agreed Delivery Date:</td>
                <td style="padding: 5px;">${object.agreed_date or 'TBD'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Driver:</td>
                <td style="padding: 5px;">${object.driver_id.name or 'TBA'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Vehicle:</td>
                <td style="padding: 5px;">${object.vehicle_id.name or 'TBA'}</td></tr>
        </table>
        <p>For any inquiries, please contact us:</p>
        <p><strong>Phone:</strong> +255 759 996 996<br/>
        <strong>Email:</strong> info@apalagroup.net</p>
        <p>Thank you for choosing Apala Logistics.</p>
    </div>
    <div style="background: #f5f5f5; padding: 10px 20px; font-size: 11px; color: #666;">
        <p>Apala Logistic Company Limited<br/>
        Dar es Salaam, Tanzania</p>
    </div>
</div>
]]></field>
        </record>

        <!-- 3.2 Trip Dispatched Notification (to customer) -->
        <record id="email_template_trip_dispatched" model="mail.template">
            <field name="name">Apala: Trip Dispatched</field>
            <field name="model_id" ref="model_apala_trip"/>
            <field name="subject">Your Cargo is on the Way — Trip ${object.name}</field>
            <field name="email_from">${(object.vehicle_id.company_id.email or 'info@apalagroup.net')|safe}</field>
            <field name="email_to">${','.join(set(filter(None, object.transport_order_ids.mapped('customer_id.email'))))}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto;">
    <div style="background: #003366; color: #ffffff; padding: 15px 20px;">
        <h2 style="margin: 0;">APALA LOGISTIC COMPANY LIMITED</h2>
    </div>
    <div style="padding: 20px; border: 1px solid #ddd;">
        <p>Dear Customer,</p>
        <p>Your cargo has been dispatched!</p>
        <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
            <tr><td style="padding: 5px; font-weight: bold;">Trip Reference:</td>
                <td style="padding: 5px;">${object.name}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Driver:</td>
                <td style="padding: 5px;">${object.driver_id.name or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Vehicle:</td>
                <td style="padding: 5px;">${object.vehicle_id.name or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Route:</td>
                <td style="padding: 5px;">${object.route_id.name or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Estimated Arrival:</td>
                <td style="padding: 5px;">${object.estimated_arrival or 'TBD'}</td></tr>
        </table>
        <p>Contact: +255 759 996 996 / info@apalagroup.net</p>
    </div>
    <div style="background: #f5f5f5; padding: 10px 20px; font-size: 11px; color: #666;">
        <p>Apala Logistic Company Limited, Dar es Salaam, Tanzania</p>
    </div>
</div>
]]></field>
        </record>

        <!-- 3.3 Delivery Confirmation / POD (to customer) -->
        <record id="email_template_delivery_confirmed" model="mail.template">
            <field name="name">Apala: Delivery Confirmed</field>
            <field name="model_id" ref="model_apala_trip"/>
            <field name="subject">Delivery Confirmed — ${object.name} | Apala Logistics</field>
            <field name="email_from">${(object.vehicle_id.company_id.email or 'info@apalagroup.net')|safe}</field>
            <field name="email_to">${','.join(set(filter(None, object.transport_order_ids.mapped('customer_id.email'))))}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto;">
    <div style="background: #003366; color: #ffffff; padding: 15px 20px;">
        <h2 style="margin: 0;">APALA LOGISTIC COMPANY LIMITED</h2>
    </div>
    <div style="padding: 20px; border: 1px solid #ddd;">
        <p>Dear Customer,</p>
        <p>We are pleased to confirm that your cargo has been delivered successfully.</p>
        <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
            <tr><td style="padding: 5px; font-weight: bold;">Trip Reference:</td>
                <td style="padding: 5px;">${object.name}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Delivery Date:</td>
                <td style="padding: 5px;">${object.arrival_date or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Route:</td>
                <td style="padding: 5px;">${object.route_id.name or '-'}</td></tr>
        </table>
        <p>Thank you for choosing Apala Logistics.</p>
        <p>Contact: +255 759 996 996 / info@apalagroup.net</p>
    </div>
    <div style="background: #f5f5f5; padding: 10px 20px; font-size: 11px; color: #666;">
        <p>Apala Logistic Company Limited, Dar es Salaam, Tanzania</p>
    </div>
</div>
]]></field>
        </record>

        <!-- 3.4 Storage Contract Expiry Warning (to customer) -->
        <record id="email_template_storage_expiry" model="mail.template">
            <field name="name">Apala: Storage Contract Expiry Warning</field>
            <field name="model_id" ref="model_apala_storage_contract"/>
            <field name="subject">Storage Contract ${object.name} Expiring Soon — Action Required</field>
            <field name="email_from">${(object.customer_id.company_id.email or 'info@apalagroup.net')|safe}</field>
            <field name="email_to">${object.customer_id.email or ''}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto;">
    <div style="background: #003366; color: #ffffff; padding: 15px 20px;">
        <h2 style="margin: 0;">APALA LOGISTIC COMPANY LIMITED</h2>
    </div>
    <div style="padding: 20px; border: 1px solid #ddd;">
        <p>Dear ${object.customer_id.name},</p>
        <p>This is to inform you that your storage contract <strong>${object.name}</strong>
        is expiring on <strong>${object.end_date}</strong>.</p>
        <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
            <tr><td style="padding: 5px; font-weight: bold;">Contract:</td>
                <td style="padding: 5px;">${object.name}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Storage Type:</td>
                <td style="padding: 5px;">${object.storage_type or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">End Date:</td>
                <td style="padding: 5px;">${object.end_date}</td></tr>
        </table>
        <p>Please contact us to discuss renewal or extension options.</p>
        <p>Contact: +255 759 996 996 / info@apalagroup.net</p>
    </div>
    <div style="background: #f5f5f5; padding: 10px 20px; font-size: 11px; color: #666;">
        <p>Apala Logistic Company Limited, Dar es Salaam, Tanzania</p>
    </div>
</div>
]]></field>
        </record>

        <!-- 3.5 Driver Document Expiry Alert (internal — to HR manager) -->
        <record id="email_template_driver_expiry_alert" model="mail.template">
            <field name="name">Apala: Driver Document Expiry Alert</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="subject">[ALERT] Driver Document Expiry — ${object.name}</field>
            <field name="email_from">${(object.company_id.email or 'info@apalagroup.net')|safe}</field>
            <field name="email_to">${','.join(set(filter(None, object.env.ref('apala_logistics.group_manager').users.mapped('email'))))}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: auto;">
    <div style="background: #cc0000; color: #ffffff; padding: 15px 20px;">
        <h2 style="margin: 0;">DRIVER DOCUMENT EXPIRY ALERT</h2>
    </div>
    <div style="padding: 20px; border: 1px solid #ddd;">
        <p>The following driver has documents expiring soon:</p>
        <table style="width: 100%; border-collapse: collapse; margin: 15px 0;">
            <tr><td style="padding: 5px; font-weight: bold;">Driver Name:</td>
                <td style="padding: 5px;">${object.name}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Licence No.:</td>
                <td style="padding: 5px;">${object.driver_licence_no or '-'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Licence Expiry:</td>
                <td style="padding: 5px;">${object.licence_expiry or 'N/A'}</td></tr>
            <tr><td style="padding: 5px; font-weight: bold;">Medical Cert Expiry:</td>
                <td style="padding: 5px;">${object.medical_cert_expiry or 'N/A'}</td></tr>
        </table>
        <p><strong>Action required:</strong> Ensure the driver renews their documents
        before expiry to maintain compliance.</p>
    </div>
</div>
]]></field>
        </record>

    </data>
</odoo>
