<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Customs Document Form View -->
    <record id="customs_document_form_view" model="ir.ui.view">
        <field name="name">apala.customs.document.form</field>
        <field name="model">apala.customs.document</field>
        <field name="arch" type="xml">
            <form string="Customs Document">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="freight_order_id"/>
                            <field name="doc_type"/>
                            <field name="document_number"/>
                            <field name="issuing_authority"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Customs Document List View -->
    <record id="customs_document_list_view" model="ir.ui.view">
        <field name="name">apala.customs.document.tree</field>
        <field name="model">apala.customs.document</field>
        <field name="arch" type="xml">
            <tree string="Customs Documents" decoration-warning="status=='pending'"
                  decoration-success="status=='approved'" decoration-danger="status=='rejected'">
                <field name="name"/>
                <field name="freight_order_id"/>
                <field name="doc_type"/>
                <field name="document_number"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <!-- Customs Document Search View -->
    <record id="customs_document_search_view" model="ir.ui.view">
        <field name="name">apala.customs.document.search</field>
        <field name="model">apala.customs.document</field>
        <field name="arch" type="xml">
            <search string="Search Customs Documents">
                <field name="name"/>
                <field name="freight_order_id"/>
                <field name="document_number"/>
                <filter string="Pending" name="pending" domain="[('status','=','pending')]"/>
                <filter string="Approved" name="approved" domain="[('status','=','approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('status','=','rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Document Type" name="group_type" context="{'group_by': 'doc_type'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Freight Order" name="group_fo" context="{'group_by': 'freight_order_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Customs Document Action -->
    <record id="action_apala_customs_document" model="ir.actions.act_window">
        <field name="name">Customs Documents</field>
        <field name="res_model">apala.customs.document</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="customs_document_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first customs document
            </p>
        </field>
    </record>

</odoo>
