<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--  Customer Credit – Form View                                 -->
    <!-- ============================================================ -->
    <record id="view_apala_customer_credit_form" model="ir.ui.view">
        <field name="name">apala.customer.credit.form</field>
        <field name="model">apala.customer.credit</field>
        <field name="arch" type="xml">
            <form string="Customer Credit Profile">
                <header>
                    <button name="action_suspend" string="Suspend"
                            type="object" class="btn-warning"
                            attrs="{'invisible': [('credit_status','!=','active')]}"/>
                    <button name="action_block" string="Block"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('credit_status','=','blocked')]}"/>
                    <button name="action_activate" string="Activate"
                            type="object" class="oe_highlight"
                            attrs="{'invisible': [('credit_status','=','active')]}"/>
                    <field name="credit_status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="partner_id" placeholder="Select Customer"/></h1>
                    </div>

                    <group>
                        <group string="Credit Terms">
                            <field name="credit_limit"/>
                            <field name="credit_days"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="risk_level"/>
                        </group>
                        <group string="Balance">
                            <field name="outstanding_balance"/>
                            <field name="credit_used_pct" widget="progressbar"/>
                            <field name="last_payment_date"/>
                            <field name="last_payment_amount"/>
                        </group>
                    </group>

                    <!-- Aging Analysis -->
                    <group string="Aging Analysis">
                        <group>
                            <field name="invoices_0_30"/>
                            <field name="invoices_31_60"/>
                        </group>
                        <group>
                            <field name="invoices_61_90"/>
                            <field name="invoices_90_plus"/>
                        </group>
                    </group>

                    <group>
                        <group string="Review">
                            <field name="reviewed_by"/>
                            <field name="reviewed_date"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2"
                               placeholder="Credit review notes..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--  Customer Credit – List View                                 -->
    <!-- ============================================================ -->
    <record id="view_apala_customer_credit_tree" model="ir.ui.view">
        <field name="name">apala.customer.credit.tree</field>
        <field name="model">apala.customer.credit</field>
        <field name="arch" type="xml">
            <tree string="Customer Credit Profiles"
                  decoration-danger="credit_status == 'blocked' or invoices_90_plus &gt; 0"
                  decoration-warning="risk_level == 'high'"
                  decoration-success="credit_status == 'active' and invoices_90_plus == 0 and invoices_61_90 == 0">
                <field name="partner_id"/>
                <field name="credit_limit"/>
                <field name="credit_days"/>
                <field name="risk_level"/>
                <field name="credit_status"/>
                <field name="outstanding_balance" sum="Total Outstanding"/>
                <field name="invoices_0_30" optional="show"/>
                <field name="invoices_31_60" optional="show"/>
                <field name="invoices_61_90" optional="show"/>
                <field name="invoices_90_plus" optional="show"/>
                <field name="last_payment_date" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--  Customer Credit – Search View                               -->
    <!-- ============================================================ -->
    <record id="view_apala_customer_credit_search" model="ir.ui.view">
        <field name="name">apala.customer.credit.search</field>
        <field name="model">apala.customer.credit</field>
        <field name="arch" type="xml">
            <search string="Search Customer Credit">
                <field name="partner_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('credit_status','=','active')]"/>
                <filter string="Suspended" name="suspended" domain="[('credit_status','=','suspended')]"/>
                <filter string="Blocked" name="blocked" domain="[('credit_status','=','blocked')]"/>
                <separator/>
                <filter string="High Risk" name="high_risk" domain="[('risk_level','=','high')]"/>
                <filter string="Has 90+ Overdue" name="overdue_90"
                        domain="[('invoices_90_plus','&gt;',0)]"/>
                <group expand="0" string="Group By">
                    <filter string="Risk Level" name="group_risk" context="{'group_by': 'risk_level'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'credit_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--  Customer Credit – Action                                    -->
    <!-- ============================================================ -->
    <record id="action_apala_customer_credit" model="ir.actions.act_window">
        <field name="name">Customer Credit Profiles</field>
        <field name="res_model">apala.customer.credit</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_apala_customer_credit_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new customer credit profile
            </p>
            <p>Manage credit limits, aging analysis, and risk levels for customers.</p>
        </field>
    </record>

</odoo>
